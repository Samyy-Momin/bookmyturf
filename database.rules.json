{
  "rules": {
    "users": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid",
        "data": {
          ".indexOn": ["turfId", "bookingDate", "time", "paymentStatus", "approvalStatus"]
        },
        "bookings": {
          ".indexOn": ["turfId", "bookingDate", "time", "paymentStatus", "approvalStatus"]
        }
      }
    },
    "turf": {
      ".read": "auth != null",
      ".write": false,
      ".indexOn": ["turfId", "bookingDate", "time", "paymentStatus"]
    }
  }
}
